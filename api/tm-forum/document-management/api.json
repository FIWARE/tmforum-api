  "info": {
    "title": "Document Specification API",
    "description": "TMF667 Document API - DocumentSpecification subset with S3 attachment offloading support. This API provides CRUD operations for DocumentSpecification entities with binary content (attachments) stored in S3-compatible object storage.",
    "version": "4.0.0"
